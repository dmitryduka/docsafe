<?xml version="1.0" encoding="utf-8"?>
<!-- The vault is encrypted and device-bound; exclude app data from cloud/device backups. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
